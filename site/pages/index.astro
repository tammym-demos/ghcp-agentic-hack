---
import Base from '../layouts/Base.astro'
import { readdirSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'
import { discoverWorkshopSkills, moduleFoldersFromMeta, workshopMeta, type ModuleMeta } from '../data/workshops'

const base = import.meta.env.BASE_URL
const workshopsDir: string = __WORKSHOPS_DIR__
const showDrafts: boolean = __SHOW_DRAFTS__
const moduleFolders = moduleFoldersFromMeta()

interface WorkshopCard {
  name: string
  label: string
  desc: string
  icon: string
  hasLab: boolean
  hasSlides: boolean
  modules?: ModuleMeta[]
  skillCount: number
}

const workshops: WorkshopCard[] = []

for (const dir of readdirSync(workshopsDir, { withFileTypes: true }).filter(d => d.isDirectory())) {
  const dirPath = resolve(workshopsDir, dir.name)
  const isDraft = existsSync(resolve(dirPath, '.draft'))
  if (isDraft && !showDrafts) continue

  if (moduleFolders.has(dir.name)) continue

  const files = readdirSync(dirPath)
  const hasWorkshop = files.some(f => f.endsWith('-workshop.md'))
  const hasLab = files.some(f => f.endsWith('-LAB.md'))
  const hasSlides = files.some(f => f.endsWith('.slidev.md'))
  const skills = discoverWorkshopSkills(workshopsDir, dir.name)
  const meta = workshopMeta[dir.name]

  if (!meta?.modules && !hasWorkshop && !hasLab && !hasSlides && skills.length === 0) continue

  const label = meta?.label ?? dir.name.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
  const desc = meta?.desc ?? ''
  const icon = meta?.icon ?? '📘'

  workshops.push({
    name: dir.name,
    label,
    desc,
    icon,
    hasLab,
    hasSlides,
    modules: meta?.modules,
    skillCount: skills.length
  })
}
---

<Base title="GitHub Workshops">
  <section class="hero">
    <div class="hero-text">
      <span class="hero-label">Developer Training</span>
      <h1 class="hero-heading">Available Workshops</h1>
      <p class="hero-description">Curated slide decks, hands-on labs, interactive quizzes, and downloadable technology skills for teams mastering GitHub Copilot.</p>
    </div>
    <div class="hero-graphic" aria-hidden="true">
      <div class="hero-grid"></div>
    </div>
  </section>

  <section class="workshops-section">
    <div class="section-intro">
      <h2 class="section-heading">Available workshops</h2>
      <p class="section-sub">Select a workshop to view its resources.</p>
    </div>

    <div class="workshop-grid">
      {workshops.map(w => (
        <a href={`${base}${w.name}`} class="workshop-card">
          <div class="card-title">
            <span class="card-icon" set:html={w.icon} />
            <h3 class="card-heading">{w.label}</h3>
          </div>
          {w.desc && <p class="card-description">{w.desc}</p>}
          <div class="card-footer">
            {w.modules ? (
              <span class="badge badge-modules">
                {w.modules.length} Modules{w.skillCount > 0 ? ` + ${w.skillCount} ${w.skillCount === 1 ? 'Skill' : 'Skills'}` : ''}
              </span>
            ) : (
              <>
                {w.hasLab && <span class="badge badge-lab">Lab</span>}
                {w.hasSlides && <span class="badge badge-slides">Slides</span>}
              </>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <style>
    .hero {
      padding: 48px 0 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 48px;
    }
    .hero-text {
      max-width: 640px;
      flex-shrink: 0;
    }
    .hero-graphic {
      position: relative;
      flex-shrink: 0;
      width: 280px;
      height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-grid {
      width: 200px;
      height: 200px;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 20px 20px;
      border-radius: 12px;
      opacity: 0.6;
    }
    @media (max-width: 768px) {
      .hero { flex-direction: column; gap: 32px; }
      .hero-graphic { width: 180px; height: 180px; }
      .hero-grid { width: 140px; height: 140px; }
    }
    .hero-label {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--brand);
      border: 1px solid rgba(9, 105, 218, 0.25);
      border-radius: 100px;
      padding: 4px 14px;
      margin-bottom: 24px;
    }
    .hero-heading {
      font-size: clamp(40px, 6vw, 64px);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
      color: var(--text-1);
      margin-bottom: 20px;
    }
    .hero-description {
      font-size: 18px;
      line-height: 1.6;
      color: var(--text-2);
    }
    .workshops-section {
      padding-bottom: 64px;
    }
    .section-intro {
      margin-bottom: 24px;
    }
    .section-heading {
      font-size: 20px;
      font-weight: 600;
      color: var(--text-1);
      margin-bottom: 4px;
      letter-spacing: -0.01em;
    }
    .section-sub {
      font-size: 14px;
      color: var(--text-2);
    }
    .workshop-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    @media (max-width: 960px) {
      .workshop-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .workshop-grid { grid-template-columns: 1fr; }
    }
    .workshop-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .workshop-card:hover {
      border-color: #afb8c1;
      box-shadow: 0 8px 24px rgba(140, 149, 159, 0.15);
      color: inherit;
    }
    .card-title {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 12px;
    }
    .card-icon {
      flex-shrink: 0;
      color: var(--text-1);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      font-size: 24px;
      line-height: 1;
    }
    .card-icon :global(svg) {
      width: 24px;
      height: 24px;
      display: block;
    }
    .card-heading {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-1);
      margin-top: 0;
      margin-bottom: 0;
      letter-spacing: -0.01em;
    }
    .card-description {
      font-size: 14px;
      line-height: 1.5;
      color: var(--text-2);
      margin-bottom: 0;
    }
    .card-footer {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: auto;
      padding-top: 20px;
    }
    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .badge-lab {
      background: rgba(26, 127, 55, 0.1);
      color: #1a7f37;
    }
    .badge-slides {
      background: rgba(130, 80, 223, 0.1);
      color: #8250df;
    }
    .badge-modules {
      background: rgba(191, 135, 0, 0.1);
      color: #9a6700;
    }
  </style>
</Base>
