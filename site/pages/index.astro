---
import Base from '../layouts/Base.astro'
import { readdirSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'

const base = import.meta.env.BASE_URL
const workshopsDir: string = __WORKSHOPS_DIR__
const showDrafts: boolean = __SHOW_DRAFTS__

// Workshop metadata — order and descriptions
// Workshops with `modules` are multi-module curricula: one parent card links to child module folders.
const workshopMeta: Record<string, { label: string; desc: string; icon: string; modules?: { folder: string; label: string; desc: string; icon: string }[]; prerequisites?: string[]; agenda?: { day: string; subtitle: string; items: { time: string; duration: string; activity: string }[] }[] }> = {
  'copilot-dev-training': {
    label: 'GitHub Copilot Dev Hack',
    desc: 'GitHub Copilot Developer Training — foundations, agentic patterns, and advanced operations.',
    icon: '🎓',
    modules: [
      { folder: 'copilot-dev-foundations', label: 'Module 1: Foundations', desc: 'Chat modes, context & instructions, models, agents, skills & customization', icon: '🎓' },
      { folder: 'copilot-dev-agentic', label: 'Module 2: Agentic Patterns', desc: 'Agents vs. skills, background & cloud agents, instruction layering, multi-agent patterns', icon: '🤖' },
      { folder: 'copilot-dev-advanced', label: 'Module 3: Advanced Topics', desc: 'MCP, APIs & plugins, memory, debugging, agentic loops & off-ramp design', icon: '🔬' }
    ],
    prerequisites: [
      'VS Code — latest stable version installed',
      'GitHub Copilot extension — installed and signed in',
      'GitHub Copilot Chat extension — installed',
      'GitHub account with Copilot access (Individual, Business, or Enterprise)',
      'GitHub CLI (gh) — installed and authenticated (run gh --version to verify)',
      'Local admin rights — ability to install extensions, CLI tools, and plugins',
      'A local project — any codebase open in VS Code (multi-file project preferred)',
      'Internet access — required for Copilot API calls'
    ],
    agenda: [
      {
        day: 'Day 1 — Modules & Labs',
        subtitle: '9:00 AM – 5:00 PM',
        items: [
          { time: '9:00 – 9:15', duration: '15 min', activity: 'Welcome & Kickoff' },
          { time: '9:15 – 10:45', duration: '90 min', activity: 'Module 1: Foundations (presentation + lab) — Speakers 1 & 2' },
          { time: '10:45 – 11:00', duration: '15 min', activity: '☕ Break' },
          { time: '11:00 – 12:55', duration: '115 min', activity: 'Module 2: Agentic Patterns (presentation + lab) — Speakers 2, 3 & 4' },
          { time: '12:55 – 1:40', duration: '45 min', activity: '🍽️ Lunch' },
          { time: '1:40 – 3:10', duration: '90 min', activity: 'Module 3: Advanced Topics (presentation + lab) — Speakers 4 & 5' },
          { time: '3:10 – 3:25', duration: '15 min', activity: '☕ Break' },
          { time: '3:25 – 4:45', duration: '80 min', activity: 'Open Lab / Hack Prep' },
          { time: '4:45 – 5:00', duration: '15 min', activity: 'Day 1 Wrap-up & Day 2 Preview' }
        ]
      },
      {
        day: 'Day 2 — Hack Day',
        subtitle: '9:00 AM – 5:00 PM',
        items: [
          { time: '9:00 – 9:15', duration: '15 min', activity: 'Day 2 Kickoff & Team Formation' },
          { time: '9:15 – 12:00', duration: '165 min', activity: '🚀 Hack — Build with Copilot' },
          { time: '12:00 – 12:45', duration: '45 min', activity: '🍽️ Lunch' },
          { time: '12:45 – 3:00', duration: '135 min', activity: '🚀 Hack — Continue Building' },
          { time: '3:00 – 4:30', duration: '90 min', activity: '🎤 Project Readouts' },
          { time: '4:30 – 5:00', duration: '30 min', activity: 'Wrap-up & Next Steps' }
        ]
      }
    ]
  },
  'copilot-workshop-c++': {
    label: 'GitHub Copilot: Zero to Agents C++',
    desc: 'From completions to fully customized agentic AI development — tailored for C++ with ODrive.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 16 16" fill="currentColor"><path d="M7.998 15.035c-4.562 0-7.873-2.914-7.998-3.749V9.338c.085-.628.677-1.686 1.588-2.065.013-.07.024-.143.036-.218.029-.183.06-.384.126-.612-.201-.508-.254-1.084-.254-1.656 0-.87.128-1.769.693-2.484.579-.733 1.494-1.124 2.724-1.261 1.206-.134 2.262.034 2.944.765.05.053.096.108.139.165.044-.057.094-.112.143-.165.682-.731 1.738-.899 2.944-.765 1.23.137 2.145.528 2.724 1.261.566.715.693 1.614.693 2.484 0 .572-.053 1.148-.254 1.656.066.228.098.429.126.612.012.076.024.148.037.218.924.385 1.522 1.471 1.591 2.095v1.872c0 .766-3.351 3.795-8.002 3.795Zm0-1.485c2.28 0 4.584-1.11 5.002-1.433V7.862l-.023-.116c-.49.21-1.075.291-1.727.291-1.146 0-2.059-.327-2.71-.991A3.222 3.222 0 0 1 8 6.303a3.24 3.24 0 0 1-.544.743c-.65.664-1.563.991-2.71.991-.652 0-1.236-.081-1.727-.291l-.023.116v4.255c.419.323 2.722 1.433 5.002 1.433ZM6.762 2.83c-.193-.206-.637-.413-1.682-.297-1.019.113-1.479.404-1.713.7-.247.312-.369.789-.369 1.554 0 .793.129 1.171.308 1.371.162.181.519.379 1.442.379.853 0 1.339-.235 1.638-.54.315-.322.527-.827.617-1.553.117-.935-.037-1.395-.241-1.614Zm4.155-.297c-1.044-.116-1.488.091-1.681.297-.204.219-.359.679-.242 1.614.091.726.303 1.231.618 1.553.299.305.784.54 1.638.54.922 0 1.28-.198 1.442-.379.179-.2.308-.578.308-1.371 0-.765-.123-1.242-.37-1.554-.233-.296-.693-.587-1.713-.7Z"/><path d="M6.25 9.037a.75.75 0 0 1 .75.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 .75-.75Zm4.25.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 1.5 0Z"/></svg>'
  }
}

// Collect the set of folders that are children of a multi-module curriculum
const moduleFolders = new Set<string>()
for (const meta of Object.values(workshopMeta)) {
  if (meta.modules) {
    for (const m of meta.modules) moduleFolders.add(m.folder)
  }
}

// Auto-discover workshops
const workshops: { name: string; label: string; desc: string; icon: string; hasWorkshop: boolean; hasLab: boolean; hasSlides: boolean; modules?: typeof workshopMeta[string]['modules'] }[] = []

for (const dir of readdirSync(workshopsDir, { withFileTypes: true }).filter(d => d.isDirectory())) {
  const dirPath = resolve(workshopsDir, dir.name)
  const isDraft = existsSync(resolve(dirPath, '.draft'))
  if (isDraft && !showDrafts) continue

  // Skip folders that are children of a multi-module curriculum
  if (moduleFolders.has(dir.name)) continue

  const files = readdirSync(dirPath)
  const hasWorkshop = files.some(f => f.endsWith('-workshop.md'))
  const hasLab = files.some(f => f.endsWith('-LAB.md'))
  const hasSlides = files.some(f => f.endsWith('.slidev.md'))

  const meta = workshopMeta[dir.name]

  // Multi-module parent folders don't need standard files — they use the modules list
  if (!meta?.modules && !hasWorkshop && !hasLab && !hasSlides) continue

  const label = meta?.label ?? dir.name.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
  const desc = meta?.desc ?? ''
  const icon = meta?.icon ?? '📘'

  workshops.push({ name: dir.name, label, desc, icon, hasWorkshop, hasLab, hasSlides, modules: meta?.modules })
}
---

<Base title="GitHub Workshops">
  <section class="hero">
    <div class="hero-text">
      <span class="hero-label">Developer Training</span>
      <h1 class="hero-heading">Available Workshops</h1>
      <p class="hero-description">Curated slide decks, hands-on labs, and interactive quizzes for teams mastering GitHub Copilot — from foundations to agentic patterns.</p>
    </div>
    <div class="hero-graphic" aria-hidden="true">
      <div class="hero-grid"></div>
    </div>
  </section>

  <section class="workshops-section">
    <div class="section-intro">
      <h2 class="section-heading">Available workshops</h2>
      <p class="section-sub">Select a workshop to view its resources.</p>
    </div>

    <div class="workshop-grid">
      {workshops.map(w => (
        <a href={`${base}${w.name}`} class="workshop-card">
          <div class="card-title">
            <span class="card-icon" set:html={w.icon} />
            <h3 class="card-heading">{w.label}</h3>
          </div>
          {w.desc && <p class="card-description">{w.desc}</p>}
          <div class="card-footer">
            {w.modules ? (
              <span class="badge badge-modules">{w.modules.length} Modules</span>
            ) : (
              <>
                {/* w.hasWorkshop && <span class="badge badge-workshop">Workshop</span> */}
                {w.hasLab && <span class="badge badge-lab">Lab</span>}
                {w.hasSlides && <span class="badge badge-slides">Slides</span>}
              </>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <style>
    /* ── Hero (PPTX-inspired: light, geometric, bold) ── */
    .hero {
      padding: 48px 0 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 48px;
    }
    .hero-text {
      max-width: 640px;
      flex-shrink: 0;
    }
    .hero-graphic {
      position: relative;
      flex-shrink: 0;
      width: 280px;
      height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-grid {
      width: 200px;
      height: 200px;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 20px 20px;
      border-radius: 12px;
      opacity: 0.6;
    }
    @media (max-width: 768px) {
      .hero { flex-direction: column; gap: 32px; }
      .hero-graphic { width: 180px; height: 180px; }
      .hero-grid { width: 140px; height: 140px; }
    }
    .hero-label {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--brand);
      border: 1px solid rgba(9, 105, 218, 0.25);
      border-radius: 100px;
      padding: 4px 14px;
      margin-bottom: 24px;
    }
    .hero-heading {
      font-size: clamp(40px, 6vw, 64px);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
      color: var(--text-1);
      margin-bottom: 20px;
    }
    .hero-description {
      font-size: 18px;
      line-height: 1.6;
      color: var(--text-2);
    }

    /* ── Section intro ── */
    .workshops-section {
      padding-bottom: 64px;
    }
    .section-intro {
      margin-bottom: 24px;
    }
    .section-heading {
      font-size: 20px;
      font-weight: 600;
      color: var(--text-1);
      margin-bottom: 4px;
      letter-spacing: -0.01em;
    }
    .section-sub {
      font-size: 14px;
      color: var(--text-2);
    }

    /* ── Grid ── */
    .workshop-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    @media (max-width: 960px) { .workshop-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .workshop-grid { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .workshop-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .workshop-card:hover {
      border-color: #afb8c1;
      box-shadow: 0 8px 24px rgba(140, 149, 159, 0.15);
      color: inherit;
    }

    .card-title {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 12px;
    }
    .card-icon {
      flex-shrink: 0;
      color: var(--text-1);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      font-size: 24px;
      line-height: 1;
    }
    .card-icon :global(svg) {
      width: 24px;
      height: 24px;
      display: block;
    }
    .card-heading {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-1);
      margin-top: 0;
      margin-bottom: 0;
      letter-spacing: -0.01em;
    }
    .card-description {
      font-size: 14px;
      line-height: 1.5;
      color: var(--text-2);
      margin-bottom: 0;
    }

    .card-footer {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: auto;
      padding-top: 20px;
    }

    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .badge-workshop {
      background: rgba(9, 105, 218, 0.1);
      color: #0969da;
    }
    .badge-lab {
      background: rgba(26, 127, 55, 0.1);
      color: #1a7f37;
    }
    .badge-slides {
      background: rgba(130, 80, 223, 0.1);
      color: #8250df;
    }
    .badge-modules {
      background: rgba(191, 135, 0, 0.1);
      color: #9a6700;
    }
  </style>
</Base>
