---
import Base from '../layouts/Base.astro'
import { readdirSync } from 'node:fs'
import { resolve } from 'node:path'

const base = import.meta.env.BASE_URL
const workshopsDir: string = __WORKSHOPS_DIR__

// Workshop metadata — order and descriptions
const workshopMeta: Record<string, { label: string; desc: string; icon: string }> = {
  'copilot-workshop': {
    label: 'Copilot: Zero to Agents',
    desc: 'From completions to fully customized agentic AI development.',
    icon: '🤖'
  },
  'copilot-governance': {
    label: 'Copilot Governance',
    desc: 'Governance and policy framework for GitHub Copilot at enterprise scale.',
    icon: '🛡️'
  },
  'ghe-governance': {
    label: 'GHE Governance',
    desc: 'GitHub Enterprise governance patterns and administration best practices.',
    icon: '🏛️'
  },
  'github-ado-integration': {
    label: 'GitHub + ADO Integration',
    desc: 'Integrating GitHub with Azure DevOps for enterprise workflows.',
    icon: '🔗'
  },
  'github-setup': {
    label: 'GitHub Setup Configurations',
    desc: 'Configuration options and setup patterns for GitHub Enterprise.',
    icon: '⚙️'
  },
  'github-migration': {
    label: 'Platform Migration',
    desc: 'Step-by-step migration guides from Bitbucket, GitLab, ADO, and Atlassian.',
    icon: '🚀'
  }
}

// Auto-discover workshops
const workshops: { name: string; label: string; desc: string; icon: string; hasLab: boolean; hasSlides: boolean }[] = []

for (const dir of readdirSync(workshopsDir, { withFileTypes: true }).filter(d => d.isDirectory())) {
  const files = readdirSync(resolve(workshopsDir, dir.name))
  const hasLab = files.some(f => f.endsWith('-LAB.md'))
  const hasSlides = files.some(f => f.endsWith('.slidev.md'))
  if (!hasLab && !hasSlides) continue

  const meta = workshopMeta[dir.name]
  const label = meta?.label ?? dir.name.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
  const desc = meta?.desc ?? ''
  const icon = meta?.icon ?? '📘'

  workshops.push({ name: dir.name, label, desc, icon, hasLab, hasSlides })
}
---

<Base title="GitHub Workshops">
  <section class="hero">
    <span class="hero-label">Enterprise Training</span>
    <h1 class="hero-heading">GitHub Workshops</h1>
    <p class="hero-description">Curated slide decks, hands-on labs, and demo scripts for enterprise teams adopting GitHub.</p>
  </section>

  <section class="workshops-section">
    <div class="section-intro">
      <h2 class="section-heading">Available workshops</h2>
      <p class="section-sub">Select a workshop to launch the slide deck or hands-on lab.</p>
    </div>

    <div class="workshop-grid">
      {workshops.map(w => (
        <div class="workshop-card">
          <div class="card-icon">{w.icon}</div>
          <h3 class="card-heading">{w.label}</h3>
          {w.desc && <p class="card-description">{w.desc}</p>}
          <div class="card-footer">
            {w.hasLab && <a href={`${base}${w.name}/lab.html`} class="badge badge-lab">Lab</a>}
            {w.hasSlides && <a href={`${base}${w.name}/slides/1`} target="_blank" rel="noopener noreferrer" onclick="window.open(this.href,'_blank','width=1280,height=720,menubar=no,toolbar=no,location=no,status=no');return false;" class="badge badge-slides">Slides</a>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <style>
    /* ── Hero (left-aligned, Primer Brand pattern) ── */
    .hero {
      padding: 80px 0 64px;
      max-width: 640px;
    }
    .hero-label {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--brand);
      border: 1px solid rgba(88, 166, 255, 0.25);
      border-radius: 100px;
      padding: 4px 14px;
      margin-bottom: 24px;
    }
    .hero-heading {
      font-size: clamp(40px, 6vw, 64px);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
      background: linear-gradient(135deg, #58a6ff 0%, #79c0ff 50%, #a5d6ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 20px;
    }
    .hero-description {
      font-size: 18px;
      line-height: 1.6;
      color: var(--text-2);
    }

    /* ── Section intro ── */
    .workshops-section {
      padding-bottom: 80px;
    }
    .section-intro {
      margin-bottom: 32px;
    }
    .section-heading {
      font-size: 20px;
      font-weight: 600;
      color: var(--text-1);
      margin-bottom: 4px;
      letter-spacing: -0.01em;
    }
    .section-sub {
      font-size: 14px;
      color: var(--text-2);
    }

    /* ── Grid ── */
    .workshop-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    @media (max-width: 960px) { .workshop-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .workshop-grid { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .workshop-card {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .workshop-card:hover {
      border-color: #484f58;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(88, 166, 255, 0.1);
    }

    .card-icon {
      font-size: 28px;
      margin-bottom: 16px;
      line-height: 1;
    }
    .card-heading {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-1);
      margin-bottom: 6px;
      letter-spacing: -0.01em;
    }
    .card-description {
      font-size: 14px;
      line-height: 1.5;
      color: var(--text-2);
      margin-bottom: 0;
    }

    .card-footer {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: auto;
      padding-top: 20px;
    }

    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      text-decoration: none;
      transition: opacity 0.15s;
    }
    .badge:hover {
      opacity: 0.8;
    }
    .badge-lab {
      background: rgba(63, 185, 80, 0.15);
      color: #3fb950;
    }
    .badge-slides {
      background: rgba(210, 168, 255, 0.15);
      color: #d2a8ff;
    }
  </style>
</Base>
