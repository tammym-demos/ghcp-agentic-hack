---
import Base from '../layouts/Base.astro'
import { readdirSync } from 'node:fs'
import { resolve } from 'node:path'

const base = import.meta.env.BASE_URL
const workshopsDir: string = __WORKSHOPS_DIR__

// Workshop metadata — order and descriptions
const workshopMeta: Record<string, { label: string; desc: string; icon: string }> = {
  'copilot-workshop': {
    label: 'Copilot: Zero to Agents',
    desc: 'From completions to fully customized agentic AI development.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 16 16" fill="currentColor"><path d="M7.998 15.035c-4.562 0-7.873-2.914-7.998-3.749V9.338c.085-.628.677-1.686 1.588-2.065.013-.07.024-.143.036-.218.029-.183.06-.384.126-.612-.201-.508-.254-1.084-.254-1.656 0-.87.128-1.769.693-2.484.579-.733 1.494-1.124 2.724-1.261 1.206-.134 2.262.034 2.944.765.05.053.096.108.139.165.044-.057.094-.112.143-.165.682-.731 1.738-.899 2.944-.765 1.23.137 2.145.528 2.724 1.261.566.715.693 1.614.693 2.484 0 .572-.053 1.148-.254 1.656.066.228.098.429.126.612.012.076.024.148.037.218.924.385 1.522 1.471 1.591 2.095v1.872c0 .766-3.351 3.795-8.002 3.795Zm0-1.485c2.28 0 4.584-1.11 5.002-1.433V7.862l-.023-.116c-.49.21-1.075.291-1.727.291-1.146 0-2.059-.327-2.71-.991A3.222 3.222 0 0 1 8 6.303a3.24 3.24 0 0 1-.544.743c-.65.664-1.563.991-2.71.991-.652 0-1.236-.081-1.727-.291l-.023.116v4.255c.419.323 2.722 1.433 5.002 1.433ZM6.762 2.83c-.193-.206-.637-.413-1.682-.297-1.019.113-1.479.404-1.713.7-.247.312-.369.789-.369 1.554 0 .793.129 1.171.308 1.371.162.181.519.379 1.442.379.853 0 1.339-.235 1.638-.54.315-.322.527-.827.617-1.553.117-.935-.037-1.395-.241-1.614Zm4.155-.297c-1.044-.116-1.488.091-1.681.297-.204.219-.359.679-.242 1.614.091.726.303 1.231.618 1.553.299.305.784.54 1.638.54.922 0 1.28-.198 1.442-.379.179-.2.308-.578.308-1.371 0-.765-.123-1.242-.37-1.554-.233-.296-.693-.587-1.713-.7Z"/><path d="M6.25 9.037a.75.75 0 0 1 .75.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 .75-.75Zm4.25.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 1.5 0Z"/></svg>'
  },
  'copilot-governance': {
    label: 'Copilot Governance',
    desc: 'Governance and policy framework for GitHub Copilot at enterprise scale.',
    icon: '🛡️'
  },
  'ghe-governance': {
    label: 'GHE Governance',
    desc: 'GitHub Enterprise governance patterns and administration best practices.',
    icon: '🏛️'
  },
  'github-ado-integration': {
    label: 'GitHub + ADO Integration',
    desc: 'Integrating GitHub with Azure DevOps for enterprise workflows.',
    icon: '🔗'
  },
  'github-setup': {
    label: 'GitHub Setup Configurations',
    desc: 'Configuration options and setup patterns for GitHub Enterprise.',
    icon: '⚙️'
  },
  'github-migration': {
    label: 'Platform Migration',
    desc: 'Step-by-step migration guides from Bitbucket, GitLab, ADO, and Atlassian.',
    icon: '🚀'
  },
  'ghas': {
    label: 'GitHub Advanced Security',
    desc: 'Code scanning, secret detection, and supply chain security for enterprise repositories.',
    icon: '🔒'
  }
}

// Auto-discover workshops
const workshops: { name: string; label: string; desc: string; icon: string; hasLab: boolean; hasSlides: boolean }[] = []

for (const dir of readdirSync(workshopsDir, { withFileTypes: true }).filter(d => d.isDirectory())) {
  const files = readdirSync(resolve(workshopsDir, dir.name))
  const hasLab = files.some(f => f.endsWith('-LAB.md'))
  const hasSlides = files.some(f => f.endsWith('.slidev.md'))
  if (!hasLab && !hasSlides) continue

  const meta = workshopMeta[dir.name]
  const label = meta?.label ?? dir.name.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
  const desc = meta?.desc ?? ''
  const icon = meta?.icon ?? '📘'

  workshops.push({ name: dir.name, label, desc, icon, hasLab, hasSlides })
}
---

<Base title="GitHub Workshops">
  <section class="hero">
    <div class="hero-text">
      <span class="hero-label">Enterprise Training</span>
      <h1 class="hero-heading">GitHub Workshops</h1>
      <p class="hero-description">Curated slide decks, hands-on labs, and demo scripts for enterprise teams adopting GitHub.</p>
    </div>
    <div class="hero-graphic" aria-hidden="true">
      <svg class="hero-octocat" viewBox="0 0 98 96" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" fill="white" d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"/>
      </svg>
    </div>
  </section>

  <section class="workshops-section">
    <div class="section-intro">
      <h2 class="section-heading">Available workshops</h2>
      <p class="section-sub">Select a workshop to launch the slide deck or hands-on lab.</p>
    </div>

    <div class="workshop-grid">
      {workshops.map(w => (
        <div class="workshop-card">
          <div class="card-title">
            <span class="card-icon" set:html={w.icon} />
            <h3 class="card-heading">{w.label}</h3>
          </div>
          {w.desc && <p class="card-description">{w.desc}</p>}
          <div class="card-footer">
            {w.hasLab && <a href={`${base}${w.name}/lab.html`} class="badge badge-lab">Lab</a>}
            {w.hasSlides && <a href={`${base}${w.name}/slides/1`} target="_blank" rel="noopener noreferrer" onclick="window.open(this.href,'_blank','width=1280,height=720,menubar=no,toolbar=no,location=no,status=no');return false;" class="badge badge-slides">Slides</a>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <style>
    /* ── Hero (left-aligned, Primer Brand pattern) ── */
    .hero {
      padding: 80px 0 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 48px;
    }
    .hero-text {
      max-width: 640px;
      flex-shrink: 0;
    }
    .hero-graphic {
      position: relative;
      flex-shrink: 0;
      width: 280px;
      height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-octocat {
      width: 200px;
      height: 200px;
      opacity: 0.85;
    }
    @media (max-width: 768px) {
      .hero { flex-direction: column; gap: 32px; }
      .hero-graphic { width: 180px; height: 180px; }
      .hero-octocat { width: 140px; height: 140px; }
    }
    .hero-label {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--brand);
      border: 1px solid rgba(88, 166, 255, 0.25);
      border-radius: 100px;
      padding: 4px 14px;
      margin-bottom: 24px;
    }
    .hero-heading {
      font-size: clamp(40px, 6vw, 64px);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
      background: linear-gradient(135deg, #58a6ff 0%, #79c0ff 50%, #a5d6ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 20px;
    }
    .hero-description {
      font-size: 18px;
      line-height: 1.6;
      color: var(--text-2);
    }

    /* ── Section intro ── */
    .workshops-section {
      padding-bottom: 80px;
    }
    .section-intro {
      margin-bottom: 32px;
    }
    .section-heading {
      font-size: 20px;
      font-weight: 600;
      color: var(--text-1);
      margin-bottom: 4px;
      letter-spacing: -0.01em;
    }
    .section-sub {
      font-size: 14px;
      color: var(--text-2);
    }

    /* ── Grid ── */
    .workshop-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    @media (max-width: 960px) { .workshop-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .workshop-grid { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .workshop-card {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .workshop-card:hover {
      border-color: #484f58;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(88, 166, 255, 0.1);
    }

    .card-title {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 6px;
    }
    .card-icon {
      font-size: 24px;
      line-height: 1;
      flex-shrink: 0;
      color: var(--text-1);
    }
    .card-icon :global(svg) {
      width: 24px;
      height: 24px;
      vertical-align: middle;
    }
    .card-heading {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-1);
      margin-bottom: 6px;
      letter-spacing: -0.01em;
    }
    .card-description {
      font-size: 14px;
      line-height: 1.5;
      color: var(--text-2);
      margin-bottom: 0;
    }

    .card-footer {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: auto;
      padding-top: 20px;
    }

    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      text-decoration: none;
      transition: opacity 0.15s;
    }
    .badge:hover {
      opacity: 0.8;
    }
    .badge-lab {
      background: rgba(63, 185, 80, 0.15);
      color: #3fb950;
    }
    .badge-slides {
      background: rgba(210, 168, 255, 0.15);
      color: #d2a8ff;
    }
  </style>
</Base>
