---
import Base from '../../layouts/Base.astro'
import { readdirSync, readFileSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'
import { marked } from 'marked'
import 'github-markdown-css/github-markdown-dark.css'

export function getStaticPaths() {
  const workshopsDir: string = __WORKSHOPS_DIR__
  const showDrafts: boolean = __SHOW_DRAFTS__
  const paths: { params: { workshop: string }; props: { html: string; title: string } }[] = []

  for (const dir of readdirSync(workshopsDir, { withFileTypes: true }).filter(d => d.isDirectory())) {
    const dirPath = resolve(workshopsDir, dir.name)
    const isDraft = existsSync(resolve(dirPath, '.draft'))
    if (isDraft && !showDrafts) continue

    const files = readdirSync(dirPath)
    const labFile = files.find(f => f.endsWith('-LAB.md'))
    if (!labFile) continue

    const content = readFileSync(resolve(dirPath, labFile), 'utf-8')
    const titleMatch = content.match(/^#\s+(.+)/m)
    const title = titleMatch ? titleMatch[1] : dir.name
    const html = marked.parse(content) as string

    paths.push({
      params: { workshop: dir.name },
      props: { html, title }
    })
  }
  return paths
}

const { html, title } = Astro.props
---

<Base title={title}>
  <article class="markdown-body" set:html={html}>
  </article>
</Base>

<style is:global>
  .markdown-body {
    background: transparent;
  }

  /* Copy button on code blocks */
  .markdown-body pre {
    position: relative;
  }
  .copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 4px 8px;
    border: 1px solid var(--border, #30363d);
    border-radius: 6px;
    background: var(--bg-soft, #161b22);
    color: var(--text-2, #8b949e);
    cursor: pointer;
    font-size: 12px;
    line-height: 1;
    opacity: 0;
    transition: opacity 0.15s;
  }
  pre:hover .copy-btn {
    opacity: 1;
  }
  .copy-btn:hover {
    color: var(--text-1, #e6edf3);
    border-color: var(--text-2, #8b949e);
  }
  .copy-btn.copied {
    color: #3fb950;
    border-color: #3fb950;
  }
</style>

<script>
  document.querySelectorAll('pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      const text = (code || pre).textContent || '';
      await navigator.clipboard.writeText(text);
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = 'Copy';
        btn.classList.remove('copied');
      }, 2000);
    });
    pre.appendChild(btn);
  });
</script>
