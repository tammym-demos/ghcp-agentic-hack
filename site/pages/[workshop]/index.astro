---
import Base from '../../layouts/Base.astro'
import { readdirSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'

const base = import.meta.env.BASE_URL

export function getStaticPaths() {
  const workshopsDir: string = __WORKSHOPS_DIR__
  const showDrafts: boolean = __SHOW_DRAFTS__
  const workshopMeta: Record<string, { label: string; desc: string; icon: string; modules?: { folder: string; label: string; desc: string; icon: string }[]; prerequisites?: string[]; agenda?: { day: string; subtitle: string; items: { time: string; duration: string; activity: string; topics?: string[] }[] }[] }> = {
    'copilot-dev-training': {
      label: 'GitHub Copilot Dev Hack',
      desc: 'GitHub Copilot Developer Training — foundations, agentic patterns, and advanced operations.',
      icon: '🎓',
      modules: [
        { folder: 'copilot-dev-foundations', label: 'Module 1: Foundations', desc: 'Chat modes, context & instructions, models, agents, skills & customization', icon: '🎓' },
        { folder: 'copilot-dev-agentic', label: 'Module 2: Agentic Patterns', desc: 'Agents vs. skills, background & cloud agents, instruction layering, multi-agent patterns', icon: '🤖' },
        { folder: 'copilot-dev-advanced', label: 'Module 3: Advanced Topics', desc: 'MCP, APIs & plugins, memory, debugging, agentic loops & off-ramp design', icon: '🔬' }
        ],
        prerequisites: [
          'VS Code — latest stable version installed',
          'GitHub Copilot extension — installed and signed in',
          'GitHub Copilot Chat extension — installed',
          'GitHub account with Copilot access (Individual, Business, or Enterprise)',
          'GitHub CLI (gh) — installed and authenticated (run gh --version to verify)',
          'Local admin rights — ability to install extensions, CLI tools, and plugins',
          'A local project — any codebase open in VS Code (multi-file project preferred)',
          'Internet access — required for Copilot API calls'
        ],
        agenda: [
          {
            day: 'Day 1 — Modules & Labs',
            subtitle: '9:00 AM – 5:00 PM',
            items: [
              { time: '9:00 – 9:15', duration: '15 min', activity: 'Welcome & Kickoff' },
              { time: '9:15 – 10:45', duration: '90 min', activity: 'Module 1: Foundations (presentation + lab) — Speakers 1 & 2', topics: ['Copilot chat modes and interaction patterns', 'Context, instructions, and prompt discipline', 'Models, agents, skills, and customization'] },
              { time: '10:45 – 11:00', duration: '15 min', activity: '☕ Break' },
              { time: '11:00 – 12:55', duration: '115 min', activity: 'Module 2: Agentic Patterns (presentation + lab) — Speakers 2, 3 & 4', topics: ['Agents vs. skills and when to use each', 'Background and cloud agents', 'Instruction layering and multi-agent patterns', 'Agent quality, token optimization, and iteration loops'] },
              { time: '12:55 – 1:40', duration: '45 min', activity: '🍽️ Lunch' },
              { time: '1:40 – 3:10', duration: '90 min', activity: 'Module 3: Advanced Topics (presentation + lab) — Speakers 4 & 5', topics: ['MCP, APIs, and extensions', 'Memory, debugging, and diagnostics', 'Agent architecture patterns and off-ramp design', 'Full-stack agent workflows and best practices'] },
              { time: '3:10 – 3:25', duration: '15 min', activity: '☕ Break' },
              { time: '3:25 – 4:45', duration: '80 min', activity: 'Open Lab / Hack Prep' },
              { time: '4:45 – 5:00', duration: '15 min', activity: 'Day 1 Wrap-up & Day 2 Preview' }
            ]
          },
          {
            day: 'Day 2 — Hack Day',
            subtitle: '9:00 AM – 5:00 PM',
            items: [
              { time: '9:00 – 9:15', duration: '15 min', activity: 'Day 2 Kickoff & Team Formation' },
              { time: '9:15 – 12:00', duration: '165 min', activity: '🚀 Hack — Build with Copilot' },
              { time: '12:00 – 12:45', duration: '45 min', activity: '🍽️ Lunch' },
              { time: '12:45 – 3:00', duration: '135 min', activity: '🚀 Hack — Continue Building' },
              { time: '3:00 – 4:30', duration: '90 min', activity: '🎤 Project Readouts' },
              { time: '4:30 – 5:00', duration: '30 min', activity: 'Wrap-up & Next Steps' }
            ]
          }
        ]
      },
    'copilot-workshop-c++': {
      label: 'GitHub Copilot: Zero to Agents C++',
      desc: 'From completions to fully customized agentic AI development — tailored for C++ with ODrive.',
      icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 16 16" fill="currentColor"><path d="M7.998 15.035c-4.562 0-7.873-2.914-7.998-3.749V9.338c.085-.628.677-1.686 1.588-2.065.013-.07.024-.143.036-.218.029-.183.06-.384.126-.612-.201-.508-.254-1.084-.254-1.656 0-.87.128-1.769.693-2.484.579-.733 1.494-1.124 2.724-1.261 1.206-.134 2.262.034 2.944.765.05.053.096.108.139.165.044-.057.094-.112.143-.165.682-.731 1.738-.899 2.944-.765 1.23.137 2.145.528 2.724 1.261.566.715.693 1.614.693 2.484 0 .572-.053 1.148-.254 1.656.066.228.098.429.126.612.012.076.024.148.037.218.924.385 1.522 1.471 1.591 2.095v1.872c0 .766-3.351 3.795-8.002 3.795Zm0-1.485c2.28 0 4.584-1.11 5.002-1.433V7.862l-.023-.116c-.49.21-1.075.291-1.727.291-1.146 0-2.059-.327-2.71-.991A3.222 3.222 0 0 1 8 6.303a3.24 3.24 0 0 1-.544.743c-.65.664-1.563.991-2.71.991-.652 0-1.236-.081-1.727-.291l-.023.116v4.255c.419.323 2.722 1.433 5.002 1.433ZM6.762 2.83c-.193-.206-.637-.413-1.682-.297-1.019.113-1.479.404-1.713.7-.247.312-.369.789-.369 1.554 0 .793.129 1.171.308 1.371.162.181.519.379 1.442.379.853 0 1.339-.235 1.638-.54.315-.322.527-.827.617-1.553.117-.935-.037-1.395-.241-1.614Zm4.155-.297c-1.044-.116-1.488.091-1.681.297-.204.219-.359.679-.242 1.614.091.726.303 1.231.618 1.553.299.305.784.54 1.638.54.922 0 1.28-.198 1.442-.379.179-.2.308-.578.308-1.371 0-.765-.123-1.242-.37-1.554-.233-.296-.693-.587-1.713-.7Z"/><path d="M6.25 9.037a.75.75 0 0 1 .75.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 .75-.75Zm4.25.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 1.5 0Z"/></svg>'
    }
  }

  const paths: { params: { workshop: string }; props: { label: string; desc: string; icon: string; hasWorkshop: boolean; hasLab: boolean; hasSlides: boolean; hasQuiz: boolean; modules?: typeof workshopMeta[string]['modules']; prerequisites?: string[]; agenda?: typeof workshopMeta[string]['agenda'] } }[] = []

  for (const dir of readdirSync(workshopsDir, { withFileTypes: true }).filter(d => d.isDirectory())) {
    const dirPath = resolve(workshopsDir, dir.name)
    const isDraft = existsSync(resolve(dirPath, '.draft'))
    if (isDraft && !showDrafts) continue

    const files = readdirSync(dirPath)
    const hasWorkshop = files.some(f => f.endsWith('-workshop.md'))
    const hasLab = files.some(f => f.endsWith('-LAB.md'))
    const hasSlides = files.some(f => f.endsWith('.slidev.md'))
    const hasQuiz = files.some(f => f.endsWith('-QUIZ.md'))

    const meta = workshopMeta[dir.name]
    if (!meta?.modules && !hasWorkshop && !hasLab && !hasSlides) continue

    const label = meta?.label ?? dir.name.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
    const desc = meta?.desc ?? ''
    const icon = meta?.icon ?? '📘'

    paths.push({
      params: { workshop: dir.name },
      props: { label, desc, icon, hasWorkshop, hasLab, hasSlides, hasQuiz, modules: meta?.modules, prerequisites: meta?.prerequisites, agenda: meta?.agenda }
    })
  }
  return paths
}

const { label, desc, icon, hasWorkshop, hasLab, hasSlides, hasQuiz, modules, prerequisites, agenda } = Astro.props
const { workshop } = Astro.params
const workshopsDir: string = __WORKSHOPS_DIR__
---

<Base title={label}>
  <div class="workshop-page">
    <div class="workshop-header">
      <span class="workshop-icon" set:html={icon} />
      <div>
        <h1 class="workshop-title">{label}</h1>
        {desc && <p class="workshop-desc">{desc}</p>}
      </div>
    </div>

    <div class="resource-grid">
      {modules ? (
        modules.map(m => {
          const mDir = resolve(workshopsDir, m.folder)
          const mFiles = existsSync(mDir) ? readdirSync(mDir) : []
          const mHasLab = mFiles.some((f: string) => f.endsWith('-LAB.md'))
          const mHasSlides = mFiles.some((f: string) => f.endsWith('.slidev.md'))
          const mHasQuiz = mFiles.some((f: string) => f.endsWith('-QUIZ.md'))
          return (
          <div class="module-card">
            <div class="module-header">
              <span class="module-icon">{m.icon}</span>
              <div>
                <h2 class="module-title">{m.label}</h2>
                <p class="module-desc">{m.desc}</p>
              </div>
            </div>
            <div class="module-links">
              {mHasLab && <a href={`${base}${m.folder}/lab`} class="module-link module-link-lab">Lab</a>}
              {mHasSlides && <a href={`${base}${m.folder}/slides/1`} target="_blank" rel="noopener noreferrer" onclick={`window.open(this.href,'_blank','width=1280,height=720,menubar=no,toolbar=no,location=no,status=no');return false;`} class="module-link module-link-slides">Slides</a>}
              {mHasQuiz && <a href={`${base}${m.folder}/quiz`} class="module-link module-link-quiz">Quiz</a>}
            </div>
          </div>
          )
        })
      ) : (
      <>
      {false && hasWorkshop && (
        <a href={`${base}${workshop}/workshop`} class="resource-card">
          <div class="resource-icon workshop-guide-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.75A.75.75 0 01.75 1h4.253c1.227 0 2.317.59 3 1.501A3.744 3.744 0 0111.006 1h4.245a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75h-4.507a2.25 2.25 0 00-1.591.659l-.622.621a.75.75 0 01-1.06 0l-.622-.621A2.25 2.25 0 005.258 13H.75a.75.75 0 01-.75-.75Zm7.251 10.324.004-5.073-.002-2.253A2.25 2.25 0 005.003 2.5H1.5v9h3.757a3.75 3.75 0 011.994.574ZM8.755 4.75l-.004 7.322a3.752 3.752 0 011.992-.572H14.5v-9h-3.495a2.25 2.25 0 00-2.25 2.25Z"/></svg>
          </div>
          <h2 class="resource-title">Workshop Guide</h2>
          <p class="resource-desc">Full workshop content with discussion points and demos.</p>
          <span class="resource-action">Open Workshop →</span>
        </a>
      )}
      {hasLab && (
        <a href={`${base}${workshop}/lab`} class="resource-card">
          <div class="resource-icon lab-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 16 16" fill="currentColor"><path d="M11.28 3.22a.75.75 0 010 1.06L4.56 11H7.75a.75.75 0 010 1.5h-5a.75.75 0 01-.75-.75v-5a.75.75 0 011.5 0v3.19l6.72-6.72a.75.75 0 011.06 0zM12.78 3.22a.75.75 0 010 1.06l-1.97 1.97a.75.75 0 11-1.06-1.06l1.97-1.97a.75.75 0 011.06 0z"/><path d="M5.72 4.47a.75.75 0 011.06 0l4.75 4.75a.75.75 0 01-1.06 1.06L5.72 5.53a.75.75 0 010-1.06z"/></svg>
          </div>
          <h2 class="resource-title">Hands-on Lab</h2>
          <p class="resource-desc">Step-by-step exercises with guided instructions.</p>
          <span class="resource-action">Open Lab →</span>
        </a>
      )}
      {hasSlides && (
        <a href={`${base}${workshop}/slides/1`} target="_blank" rel="noopener noreferrer" onclick="window.open(this.href,'_blank','width=1280,height=720,menubar=no,toolbar=no,location=no,status=no');return false;" class="resource-card">
          <div class="resource-icon slides-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 16 16" fill="currentColor"><path d="M0 3.75C0 2.784.784 2 1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0114.25 14H1.75A1.75 1.75 0 010 12.25Zm1.75-.25a.25.25 0 00-.25.25v8.5c0 .138.112.25.25.25h12.5a.25.25 0 00.25-.25v-8.5a.25.25 0 00-.25-.25ZM6 6.5a.75.75 0 01.75-.75h4.5a.75.75 0 010 1.5h-4.5A.75.75 0 016 6.5Zm.75 2.75a.75.75 0 000 1.5h4.5a.75.75 0 000-1.5h-4.5ZM4 7a1 1 0 11-2 0 1 1 0 012 0Zm-1 3a1 1 0 100-2 1 1 0 000 2Z"/></svg>
          </div>
          <h2 class="resource-title">Slide Deck</h2>
          <p class="resource-desc">Launch the presentation in a new window.</p>
          <span class="resource-action">Open Slides →</span>
        </a>
      )}
      </>
      )}
    </div>

    {prerequisites && prerequisites.length > 0 && (
      <section class="prerequisites-section">
        <h2 class="prerequisites-heading">Prerequisites</h2>
        <p class="prerequisites-sub">Participants should have the following ready before the workshop.</p>
        <ul class="prerequisites-list">
          {prerequisites.map(item => (
            <li class="prerequisites-item">
              <span class="prerequisites-check" aria-hidden="true">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {agenda && agenda.length > 0 && (
      <section class="agenda-section">
        <h2 class="agenda-heading">Agenda</h2>
        {agenda.map(day => (
          <div class="agenda-day">
            <h3 class="agenda-day-title">{day.day}</h3>
            <p class="agenda-day-subtitle">{day.subtitle}</p>
            <table class="agenda-table">
              <thead>
                <tr>
                  <th>Time</th>
                  <th>Duration</th>
                  <th>Activity</th>
                </tr>
              </thead>
              <tbody>
                {day.items.map(item => (
                  <tr>
                    <td class="agenda-time">{item.time}</td>
                    <td class="agenda-duration">{item.duration}</td>
                    <td>
                      <div class="agenda-activity">{item.activity}</div>
                      {item.topics && item.topics.length > 0 && (
                        <ul class="agenda-topics">
                          {item.topics.map(topic => <li>{topic}</li>)}
                        </ul>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))}
      </section>
    )}
  </div>
</Base>

<style>
  .workshop-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 24px 0 64px;
  }

  .workshop-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 32px;
  }

  .workshop-icon {
    flex-shrink: 0;
    color: var(--text-1);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-top: 0;
    font-size: 42px;
    line-height: 1;
  }
  .workshop-icon :global(svg) {
    width: 48px;
    height: 48px;
    display: block;
  }

  .workshop-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-1);
    margin-top: 0;
    margin-bottom: 8px;
  }

  .workshop-desc {
    font-size: 16px;
    line-height: 1.5;
    color: var(--text-2);
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 960px) {
    .resource-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .resource-grid { grid-template-columns: 1fr; }
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
  }
  .resource-card:hover {
    border-color: #afb8c1;
    box-shadow: 0 8px 24px rgba(140, 149, 159, 0.15);
    transform: translateY(-2px);
  }

  .resource-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .slides-icon {
    background: rgba(130, 80, 223, 0.1);
    color: #8250df;
  }
  .workshop-guide-icon {
    background: rgba(9, 105, 218, 0.1);
    color: #0969da;
  }
  .lab-icon {
    background: rgba(26, 127, 55, 0.1);
    color: #1a7f37;
  }

  .resource-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-1);
    margin-bottom: 4px;
  }

  .resource-desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-2);
    margin-bottom: 0;
    flex-grow: 1;
  }

  .resource-action {
    display: inline-block;
    margin-top: 16px;
    font-size: 14px;
    font-weight: 600;
    color: var(--brand);
  }
  .resource-card:hover .resource-action {
    color: var(--brand-hover);
  }

  /* Module cards for multi-module curricula */
  .module-card {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .module-card:hover {
    border-color: #afb8c1;
    box-shadow: 0 4px 16px rgba(140, 149, 159, 0.12);
  }
  .module-header {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 0;
  }
  .module-icon {
    font-size: 28px;
    flex-shrink: 0;
  }
  .module-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-1);
    margin: 0 0 2px;
  }
  .module-desc {
    font-size: 13px;
    color: var(--text-2);
    margin: 0;
    line-height: 1.4;
  }
  .module-links {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  .module-link {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .module-link:hover { opacity: 0.85; }
  .module-link-workshop {
    background: rgba(9, 105, 218, 0.1);
    color: #0969da;
  }
  .module-link-lab {
    background: rgba(26, 127, 55, 0.1);
    color: #1a7f37;
  }
  .module-link-slides {
    background: rgba(130, 80, 223, 0.1);
    color: #8250df;
  }
  .module-link-quiz {
    background: rgba(191, 135, 0, 0.1);
    color: #9a6700;
  }
  @media (max-width: 600px) {
    .module-card { flex-direction: column; align-items: flex-start; }
    .module-links { width: 100%; }
    .module-link { flex: 1; text-align: center; }
  }

  /* Prerequisites section */
  .prerequisites-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .prerequisites-heading {
    font-size: 20px;
    font-weight: 600;
    color: var(--text-1);
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .prerequisites-sub {
    font-size: 14px;
    color: var(--text-2);
    margin-bottom: 20px;
  }
  .prerequisites-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }
  .prerequisites-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-2);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
  }
  .prerequisites-check {
    color: #1a7f37;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── Agenda ── */
  .agenda-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .agenda-heading {
    font-size: 20px;
    font-weight: 600;
    color: var(--text-1);
    margin-bottom: 24px;
    letter-spacing: -0.01em;
  }
  .agenda-day {
    margin-bottom: 32px;
  }
  .agenda-day-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-1);
    margin-bottom: 2px;
  }
  .agenda-day-subtitle {
    font-size: 13px;
    color: var(--text-2);
    margin-bottom: 12px;
  }
  .agenda-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .agenda-table thead {
    background: var(--bg-soft);
  }
  .agenda-table th {
    text-align: left;
    padding: 10px 14px;
    font-weight: 600;
    color: var(--text-1);
    border-bottom: 1px solid var(--border);
  }
  .agenda-table td {
    padding: 10px 14px;
    color: var(--text-2);
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .agenda-activity {
    font-weight: 600;
    color: var(--text-1);
  }
  .agenda-topics {
    margin: 8px 0 0 18px;
    padding: 0;
    color: var(--text-2);
    font-size: 13px;
    line-height: 1.45;
  }
  .agenda-topics li + li {
    margin-top: 4px;
  }
  .agenda-table tr:last-child td {
    border-bottom: none;
  }
  .agenda-time {
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .agenda-duration {
