---
import Base from '../../layouts/Base.astro'
import { readdirSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'

const base = import.meta.env.BASE_URL

export function getStaticPaths() {
  const workshopsDir: string = __WORKSHOPS_DIR__
  const showDrafts: boolean = __SHOW_DRAFTS__
  const workshopMeta: Record<string, { label: string; desc: string; icon: string; modules?: { folder: string; label: string; desc: string; icon: string }[] }> = {
    'copilot-dev-training': {
      label: 'Copilot Developer Training',
      desc: '6-hour developer workshop — chat, context, agentic patterns, MCP, and GitHub + ADO integration.',
      icon: '🎓',
      modules: [
        { folder: 'copilot-dev-foundations', label: 'Module 1: Foundations', desc: '90 min · Chat tour, GitHub CLI, context & instructions, models & tokens', icon: '🎓' },
        { folder: 'copilot-dev-agentic', label: 'Module 2: Agentic Patterns', desc: '90 min · Context management, project bootstrap, agents & skills, agentic loops', icon: '🤖' },
        { folder: 'copilot-dev-advanced', label: 'Module 3: Advanced Topics', desc: '90 min · Agent architecture patterns, MCP setup, debugging, full-stack agents', icon: '🔬' },
        { folder: 'copilot-dev-ado-integration', label: 'Module 4: GitHub + ADO Integration', desc: '15 min · AB# linking, Copilot from Boards, decision framework', icon: '🔗' },
        { folder: 'copilot-dev-hack', label: 'Module 5: Hack', desc: '45-minute hackathon · Build custom agents for real business problems', icon: '🚀' }
      ]
    },
    'copilot-workshop': {
      label: 'GitHub Copilot: Zero to Agents',
      desc: 'From completions to fully customized agentic AI development.',
      icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 16 16" fill="currentColor"><path d="M7.998 15.035c-4.562 0-7.873-2.914-7.998-3.749V9.338c.085-.628.677-1.686 1.588-2.065.013-.07.024-.143.036-.218.029-.183.06-.384.126-.612-.201-.508-.254-1.084-.254-1.656 0-.87.128-1.769.693-2.484.579-.733 1.494-1.124 2.724-1.261 1.206-.134 2.262.034 2.944.765.05.053.096.108.139.165.044-.057.094-.112.143-.165.682-.731 1.738-.899 2.944-.765 1.23.137 2.145.528 2.724 1.261.566.715.693 1.614.693 2.484 0 .572-.053 1.148-.254 1.656.066.228.098.429.126.612.012.076.024.148.037.218.924.385 1.522 1.471 1.591 2.095v1.872c0 .766-3.351 3.795-8.002 3.795Zm0-1.485c2.28 0 4.584-1.11 5.002-1.433V7.862l-.023-.116c-.49.21-1.075.291-1.727.291-1.146 0-2.059-.327-2.71-.991A3.222 3.222 0 0 1 8 6.303a3.24 3.24 0 0 1-.544.743c-.65.664-1.563.991-2.71.991-.652 0-1.236-.081-1.727-.291l-.023.116v4.255c.419.323 2.722 1.433 5.002 1.433ZM6.762 2.83c-.193-.206-.637-.413-1.682-.297-1.019.113-1.479.404-1.713.7-.247.312-.369.789-.369 1.554 0 .793.129 1.171.308 1.371.162.181.519.379 1.442.379.853 0 1.339-.235 1.638-.54.315-.322.527-.827.617-1.553.117-.935-.037-1.395-.241-1.614Zm4.155-.297c-1.044-.116-1.488.091-1.681.297-.204.219-.359.679-.242 1.614.091.726.303 1.231.618 1.553.299.305.784.54 1.638.54.922 0 1.28-.198 1.442-.379.179-.2.308-.578.308-1.371 0-.765-.123-1.242-.37-1.554-.233-.296-.693-.587-1.713-.7Z"/><path d="M6.25 9.037a.75.75 0 0 1 .75.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 .75-.75Zm4.25.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 1.5 0Z"/></svg>'
    },
    'copilot-workshop-c++': {
      label: 'GitHub Copilot: Zero to Agents C++',
      desc: 'From completions to fully customized agentic AI development — tailored for C++ with ODrive.',
      icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 16 16" fill="currentColor"><path d="M7.998 15.035c-4.562 0-7.873-2.914-7.998-3.749V9.338c.085-.628.677-1.686 1.588-2.065.013-.07.024-.143.036-.218.029-.183.06-.384.126-.612-.201-.508-.254-1.084-.254-1.656 0-.87.128-1.769.693-2.484.579-.733 1.494-1.124 2.724-1.261 1.206-.134 2.262.034 2.944.765.05.053.096.108.139.165.044-.057.094-.112.143-.165.682-.731 1.738-.899 2.944-.765 1.23.137 2.145.528 2.724 1.261.566.715.693 1.614.693 2.484 0 .572-.053 1.148-.254 1.656.066.228.098.429.126.612.012.076.024.148.037.218.924.385 1.522 1.471 1.591 2.095v1.872c0 .766-3.351 3.795-8.002 3.795Zm0-1.485c2.28 0 4.584-1.11 5.002-1.433V7.862l-.023-.116c-.49.21-1.075.291-1.727.291-1.146 0-2.059-.327-2.71-.991A3.222 3.222 0 0 1 8 6.303a3.24 3.24 0 0 1-.544.743c-.65.664-1.563.991-2.71.991-.652 0-1.236-.081-1.727-.291l-.023.116v4.255c.419.323 2.722 1.433 5.002 1.433ZM6.762 2.83c-.193-.206-.637-.413-1.682-.297-1.019.113-1.479.404-1.713.7-.247.312-.369.789-.369 1.554 0 .793.129 1.171.308 1.371.162.181.519.379 1.442.379.853 0 1.339-.235 1.638-.54.315-.322.527-.827.617-1.553.117-.935-.037-1.395-.241-1.614Zm4.155-.297c-1.044-.116-1.488.091-1.681.297-.204.219-.359.679-.242 1.614.091.726.303 1.231.618 1.553.299.305.784.54 1.638.54.922 0 1.28-.198 1.442-.379.179-.2.308-.578.308-1.371 0-.765-.123-1.242-.37-1.554-.233-.296-.693-.587-1.713-.7Z"/><path d="M6.25 9.037a.75.75 0 0 1 .75.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 .75-.75Zm4.25.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 1.5 0Z"/></svg>'
    },
    'copilot-governance': {
      label: 'Copilot Governance',
      desc: 'Governance and policy framework for GitHub Copilot at enterprise scale.',
      icon: '🛡️'
    },
    'copilot-governance-intro': {
      label: 'Copilot Governance Intro',
      desc: 'Introduction to GitHub Copilot governance concepts and quick-start guide.',
      icon: '🛡️'
    },
    'ghe-governance': {
      label: 'GHE Governance',
      desc: 'GitHub Enterprise governance patterns and administration best practices.',
      icon: '🏛️'
    },
    'github-ado-integration': {
      label: 'GitHub + ADO Integration',
      desc: 'Integrating GitHub with Azure DevOps for enterprise workflows.',
      icon: '🔗'
    },
    'github-setup': {
      label: 'GitHub Setup Configurations',
      desc: 'Configuration options and setup patterns for GitHub Enterprise.',
      icon: '⚙️'
    },
    'github-migration': {
      label: 'Platform Migration',
      desc: 'Step-by-step migration guides from Bitbucket, GitLab, ADO, and Atlassian.',
      icon: '🚀'
    },
    'ghas': {
      label: 'GitHub Advanced Security',
      desc: 'Code scanning, secret detection, and supply chain security for enterprise repositories.',
      icon: '🔒'
    },
    'ado-setup': {
      label: 'ADO Work Management',
      desc: 'Portfolio, project, and team delivery views in Azure DevOps with Planner integration and UAT.',
      icon: '📋'
    },
    'ado-governance': {
      label: 'ADO Governance',
      desc: 'Establishing Azure DevOps as a curated managed service with formal governance, provisioning, and lifecycle management.',
      icon: '🏗️'
    },
    'copilot-governance-intro': {
      label: 'Copilot Governance — Intro',
      desc: 'A concise introduction to GitHub Copilot governance for executive and leadership audiences.',
      icon: '🛡️'
    },
    'ghe-team-management': {
      label: 'GHE Team Management',
      desc: 'Managing teams, roles, and access patterns at scale inside GitHub Enterprise.',
      icon: '👥'
    },
    'ghe-emu-oss': {
      label: 'EMU + Open Source Consumption',
      desc: 'Practical patterns for consuming open source packages and source code inside GitHub Enterprise Managed Users — approve, mirror, and stay updated.',
      icon: '📦'
    },
    'copilot-workshop-c++': {
      label: 'Copilot: Zero to Agents — C++ Edition',
      desc: 'Copilot customization and agentic workflows for embedded C++ firmware using ODrive motor controller.',
      icon: '⚙️'
    }
  }

  const paths: { params: { workshop: string }; props: { label: string; desc: string; icon: string; hasWorkshop: boolean; hasLab: boolean; hasSlides: boolean; modules?: typeof workshopMeta[string]['modules'] } }[] = []

  for (const dir of readdirSync(workshopsDir, { withFileTypes: true }).filter(d => d.isDirectory())) {
    const dirPath = resolve(workshopsDir, dir.name)
    const isDraft = existsSync(resolve(dirPath, '.draft'))
    if (isDraft && !showDrafts) continue

    const files = readdirSync(dirPath)
    const hasWorkshop = files.some(f => f.endsWith('-workshop.md'))
    const hasLab = files.some(f => f.endsWith('-LAB.md'))
    const hasSlides = files.some(f => f.endsWith('.slidev.md'))

    const meta = workshopMeta[dir.name]
    if (!meta?.modules && !hasWorkshop && !hasLab && !hasSlides) continue

    const label = meta?.label ?? dir.name.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
    const desc = meta?.desc ?? ''
    const icon = meta?.icon ?? '📘'

    paths.push({
      params: { workshop: dir.name },
      props: { label, desc, icon, hasWorkshop, hasLab, hasSlides, modules: meta?.modules }
    })
  }
  return paths
}

const { label, desc, icon, hasWorkshop, hasLab, hasSlides, modules } = Astro.props
const { workshop } = Astro.params
---

<Base title={label}>
  <div class="workshop-page">
    <div class="workshop-header">
      <span class="workshop-icon" set:html={icon} />
      <div>
        <h1 class="workshop-title">{label}</h1>
        {desc && <p class="workshop-desc">{desc}</p>}
      </div>
    </div>

    <div class="resource-grid">
      {modules ? (
        modules.map(m => (
          <div class="module-card">
            <div class="module-header">
              <span class="module-icon">{m.icon}</span>
              <div>
                <h2 class="module-title">{m.label}</h2>
                <p class="module-desc">{m.desc}</p>
              </div>
            </div>
            <div class="module-links">
              <a href={`${base}${m.folder}/lab`} class="module-link module-link-lab">Lab</a>
              <a href={`${base}${m.folder}/slides/1`} target="_blank" rel="noopener noreferrer" onclick={`window.open(this.href,'_blank','width=1280,height=720,menubar=no,toolbar=no,location=no,status=no');return false;`} class="module-link module-link-slides">Slides</a>
            </div>
          </div>
        ))
      ) : (
      <>
      {false && hasWorkshop && (
        <a href={`${base}${workshop}/workshop`} class="resource-card">
          <div class="resource-icon workshop-guide-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.75A.75.75 0 01.75 1h4.253c1.227 0 2.317.59 3 1.501A3.744 3.744 0 0111.006 1h4.245a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75h-4.507a2.25 2.25 0 00-1.591.659l-.622.621a.75.75 0 01-1.06 0l-.622-.621A2.25 2.25 0 005.258 13H.75a.75.75 0 01-.75-.75Zm7.251 10.324.004-5.073-.002-2.253A2.25 2.25 0 005.003 2.5H1.5v9h3.757a3.75 3.75 0 011.994.574ZM8.755 4.75l-.004 7.322a3.752 3.752 0 011.992-.572H14.5v-9h-3.495a2.25 2.25 0 00-2.25 2.25Z"/></svg>
          </div>
          <h2 class="resource-title">Workshop Guide</h2>
          <p class="resource-desc">Full workshop content with discussion points and demos.</p>
          <span class="resource-action">Open Workshop →</span>
        </a>
      )}
      {hasLab && (
        <a href={`${base}${workshop}/lab`} class="resource-card">
          <div class="resource-icon lab-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 16 16" fill="currentColor"><path d="M11.28 3.22a.75.75 0 010 1.06L4.56 11H7.75a.75.75 0 010 1.5h-5a.75.75 0 01-.75-.75v-5a.75.75 0 011.5 0v3.19l6.72-6.72a.75.75 0 011.06 0zM12.78 3.22a.75.75 0 010 1.06l-1.97 1.97a.75.75 0 11-1.06-1.06l1.97-1.97a.75.75 0 011.06 0z"/><path d="M5.72 4.47a.75.75 0 011.06 0l4.75 4.75a.75.75 0 01-1.06 1.06L5.72 5.53a.75.75 0 010-1.06z"/></svg>
          </div>
          <h2 class="resource-title">Hands-on Lab</h2>
          <p class="resource-desc">Step-by-step exercises with guided instructions.</p>
          <span class="resource-action">Open Lab →</span>
        </a>
      )}
      {hasSlides && (
        <a href={`${base}${workshop}/slides/1`} target="_blank" rel="noopener noreferrer" onclick="window.open(this.href,'_blank','width=1280,height=720,menubar=no,toolbar=no,location=no,status=no');return false;" class="resource-card">
          <div class="resource-icon slides-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 16 16" fill="currentColor"><path d="M0 3.75C0 2.784.784 2 1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0114.25 14H1.75A1.75 1.75 0 010 12.25Zm1.75-.25a.25.25 0 00-.25.25v8.5c0 .138.112.25.25.25h12.5a.25.25 0 00.25-.25v-8.5a.25.25 0 00-.25-.25ZM6 6.5a.75.75 0 01.75-.75h4.5a.75.75 0 010 1.5h-4.5A.75.75 0 016 6.5Zm.75 2.75a.75.75 0 000 1.5h4.5a.75.75 0 000-1.5h-4.5ZM4 7a1 1 0 11-2 0 1 1 0 012 0Zm-1 3a1 1 0 100-2 1 1 0 000 2Z"/></svg>
          </div>
          <h2 class="resource-title">Slide Deck</h2>
          <p class="resource-desc">Launch the presentation in a new window.</p>
          <span class="resource-action">Open Slides →</span>
        </a>
      )}
      </>
      )}
    </div>
  </div>
</Base>

<style>
  .workshop-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 24px 0 64px;
  }

  .workshop-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 32px;
  }

  .workshop-icon {
    flex-shrink: 0;
    color: var(--text-1);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-top: 0;
    font-size: 42px;
    line-height: 1;
  }
  .workshop-icon :global(svg) {
    width: 48px;
    height: 48px;
    display: block;
  }

  .workshop-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-1);
    margin-top: 0;
    margin-bottom: 8px;
  }

  .workshop-desc {
    font-size: 16px;
    line-height: 1.5;
    color: var(--text-2);
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 960px) {
    .resource-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .resource-grid { grid-template-columns: 1fr; }
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
  }
  .resource-card:hover {
    border-color: #484f58;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(88, 166, 255, 0.1);
    transform: translateY(-2px);
  }

  .resource-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .slides-icon {
    background: rgba(210, 168, 255, 0.15);
    color: #d2a8ff;
  }
  .workshop-guide-icon {
    background: rgba(88, 166, 255, 0.15);
    color: #58a6ff;
  }
  .lab-icon {
    background: rgba(63, 185, 80, 0.15);
    color: #3fb950;
  }

  .resource-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-1);
    margin-bottom: 4px;
  }

  .resource-desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-2);
    margin-bottom: 0;
    flex-grow: 1;
  }

  .resource-action {
    display: inline-block;
    margin-top: 16px;
    font-size: 14px;
    font-weight: 600;
    color: var(--brand);
  }
  .resource-card:hover .resource-action {
    color: var(--brand-hover);
  }

  /* Module cards for multi-module curricula */
  .module-card {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .module-card:hover {
    border-color: #484f58;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }
  .module-header {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 0;
  }
  .module-icon {
    font-size: 28px;
    flex-shrink: 0;
  }
  .module-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-1);
    margin: 0 0 2px;
  }
  .module-desc {
    font-size: 13px;
    color: var(--text-2);
    margin: 0;
    line-height: 1.4;
  }
  .module-links {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  .module-link {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .module-link:hover { opacity: 0.85; }
  .module-link-workshop {
    background: rgba(88, 166, 255, 0.15);
    color: #58a6ff;
  }
  .module-link-lab {
    background: rgba(63, 185, 80, 0.15);
    color: #3fb950;
  }
  .module-link-slides {
    background: rgba(210, 168, 255, 0.15);
    color: #d2a8ff;
  }
  @media (max-width: 600px) {
    .module-card { flex-direction: column; align-items: flex-start; }
    .module-links { width: 100%; }
    .module-link { flex: 1; text-align: center; }
  }
</style>
